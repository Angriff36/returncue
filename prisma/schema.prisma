generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  purchases     Purchase[]
  subscriptions Subscription[]
  emailScans    EmailScan[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Purchase {
  id               String   @id @default(cuid())
  userId           String
  storeName        String
  itemDescription  String
  orderDate        DateTime
  returnWindowDays Int
  deadline         DateTime
  amount           Float
  status           String   @default("KEEP")
  notes            String?
  returnPortalUrl  String?
  source           String   @default("manual")
  sourceEmailId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceEmailId])
  @@index([userId])
  @@index([deadline])
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String
  serviceName      String
  amount           Float
  currency         String   @default("USD")
  billingFrequency String   @default("unknown")
  lastBilledAt     DateTime
  nextBilledAt     DateTime?
  status           String   @default("active")
  source           String   @default("gmail_scan")
  sourceEmailId    String?  @unique
  priceHistory     Json?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextBilledAt])
}

model EmailScan {
  id             String    @id @default(cuid())
  userId         String
  status         String    @default("running")
  totalEmails     Int       @default(0)
  processedEmails Int       @default(0)
  purchasesFound  Int       @default(0)
  skippedEmails   Int       @default(0)
  currentSubject  String?
  error           String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
